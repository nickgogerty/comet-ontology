{
  "@context": {
    "@version": 1.1,

    "comet":     "https://comet.carbon/v1/core#",
    "comet-rs":  "https://comet.carbon/ext/responsiblesteel#",
    "comet-pcf": "https://comet.carbon/v1/pcf#",
    "comet-eac": "https://comet.carbon/v1/eac#",
    "comet-ver": "https://comet.carbon/v1/ver#",
    "comet-mkt": "https://comet.carbon/v1/market#",
    "comet-sc":  "https://comet.carbon/v1/supplychain#",
    "comet-ef":  "https://comet.carbon/v1/emfactor#",

    "owl":       "http://www.w3.org/2002/07/owl#",
    "rdf":       "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs":      "http://www.w3.org/2000/01/rdf-schema#",
    "xsd":       "http://www.w3.org/2001/XMLSchema#",
    "skos":      "http://www.w3.org/2004/02/skos/core#",
    "dcterms":   "http://purl.org/dc/terms/",
    "prov":      "http://www.w3.org/ns/prov#",
    "qudt":      "http://qudt.org/schema/qudt/",
    "unit":      "http://qudt.org/vocab/unit/",
    "sh":        "http://www.w3.org/ns/shacl#",

    "id":                          "@id",
    "type":                        "@type",

    "label":                       { "@id": "rdfs:label", "@language": "en" },
    "comment":                     { "@id": "rdfs:comment", "@language": "en" },
    "prefLabel":                   { "@id": "skos:prefLabel", "@language": "en" },
    "altLabel":                    { "@id": "skos:altLabel", "@language": "en" },
    "definition":                  { "@id": "skos:definition", "@language": "en" },

    "CertifiedSite":               "comet-rs:CertifiedSite",
    "CorporateOwner":              "comet-rs:CorporateOwner",
    "SteelProductionRoute":        "comet-rs:SteelProductionRoute",
    "RSInputMaterial":             "comet-rs:RSInputMaterial",
    "ScrapCategory":               "comet-rs:ScrapCategory",
    "RSSupplierTier":              "comet-rs:RSSupplierTier",
    "SupplierESGRisk":             "comet-rs:SupplierESGRisk",
    "RecognisedProgramme":         "comet-rs:RecognisedProgramme",
    "CrudeSteelIntensity":         "comet-rs:CrudeSteelIntensity",
    "ScrapShareCalculation":       "comet-rs:ScrapShareCalculation",
    "DPLThreshold":                "comet-rs:DPLThreshold",
    "ProcessGasBaseline":          "comet-rs:ProcessGasBaseline",
    "EnergyRecoveryCredit":        "comet-rs:EnergyRecoveryCredit",
    "CCUSCredit":                  "comet-rs:CCUSCredit",
    "CoreSiteCertification":       "comet-rs:CoreSiteCertification",
    "SteelCertification":          "comet-rs:SteelCertification",
    "DecarbProgressLevel":         "comet-rs:DecarbProgressLevel",
    "SourcingProgressLevel":       "comet-rs:SourcingProgressLevel",
    "CertifiedSteelMark":          "comet-rs:CertifiedSteelMark",
    "CoCTransferEvent":            "comet-rs:CoCTransferEvent",
    "CoCClaim":                    "comet-rs:CoCClaim",
    "CertificationAudit":          "comet-rs:CertificationAudit",
    "AssurancePanelReview":        "comet-rs:AssurancePanelReview",
    "NonConformity":               "comet-rs:NonConformity",
    "PrincipleConformity":         "comet-rs:PrincipleConformity",
    "TransitionPlanReview":        "comet-rs:TransitionPlanReview",
    "AmbitionGapAnalysis":         "comet-rs:AmbitionGapAnalysis",
    "ProgressLevelPricing":        "comet-rs:ProgressLevelPricing",
    "GreenSteelPremium":           "comet-rs:GreenSteelPremium",
    "RSPrinciple":                 "comet-rs:RSPrinciple",

    "BF_BOF":                      "comet-rs:BF_BOF",
    "EAF":                         "comet-rs:EAF",
    "DRI_EAF":                     "comet-rs:DRI_EAF",
    "SR_BOF":                      "comet-rs:SR_BOF",

    "certificateId":               "comet-rs:certificateId",
    "siteAuditBoundary":           "comet-rs:siteAuditBoundary",
    "annualCrudeSteelProduction":   { "@id": "comet-rs:annualCrudeSteelProduction", "@type": "xsd:decimal" },
    "metallicFraction":            { "@id": "comet-rs:metallicFraction", "@type": "xsd:decimal" },
    "materialOriginRegion":        "comet-rs:materialOriginRegion",
    "primarySecondaryClassification": "comet-rs:primarySecondaryClassification",
    "ghgIntensityValue":           { "@id": "comet-rs:ghgIntensityValue", "@type": "xsd:decimal" },
    "scrapSharePercent":           { "@id": "comet-rs:scrapSharePercent", "@type": "xsd:decimal" },
    "dplThresholdB":               { "@id": "comet-rs:dplThresholdB", "@type": "xsd:decimal" },
    "dplThresholdM":               { "@id": "comet-rs:dplThresholdM", "@type": "xsd:decimal" },
    "processGasPowerMWh":          { "@id": "comet-rs:processGasPowerMWh", "@type": "xsd:decimal" },
    "wasteEnergyPowerMWh":         { "@id": "comet-rs:wasteEnergyPowerMWh", "@type": "xsd:decimal" },
    "upstreamPowerConsumptionMWh": { "@id": "comet-rs:upstreamPowerConsumptionMWh", "@type": "xsd:decimal" },
    "dplLevel":                    { "@id": "comet-rs:dplLevel", "@type": "xsd:integer" },
    "splLevel":                    { "@id": "comet-rs:splLevel", "@type": "xsd:integer" },
    "cocModel":                    "comet-rs:cocModel",
    "transferQuantityTonnes":      { "@id": "comet-rs:transferQuantityTonnes", "@type": "xsd:decimal" },
    "nonConformitySeverity":       "comet-rs:nonConformitySeverity",
    "panelDecision":               "comet-rs:panelDecision",
    "transitionPlanReviewDate":    { "@id": "comet-rs:transitionPlanReviewDate", "@type": "xsd:date" },
    "ambitionGapDelta":            { "@id": "comet-rs:ambitionGapDelta", "@type": "xsd:decimal" },
    "premiumPerTonne":             { "@id": "comet-rs:premiumPerTonne", "@type": "xsd:decimal" },
    "premiumCurrency":             "comet-rs:premiumCurrency",

    "hasDPL":                      { "@id": "comet-rs:hasDPL", "@type": "@id" },
    "hasSPL":                      { "@id": "comet-rs:hasSPL", "@type": "@id" },
    "transfersFrom":               { "@id": "comet-rs:transfersFrom", "@type": "@id" },
    "transfersTo":                 { "@id": "comet-rs:transfersTo", "@type": "@id" },
    "traceableTo":                 { "@id": "comet-rs:traceableTo", "@type": "@id" },
    "auditedSite":                 { "@id": "comet-rs:auditedSite", "@type": "@id" },
    "reviewsAudit":                { "@id": "comet-rs:reviewsAudit", "@type": "@id" },
    "principleAssessed":           { "@id": "comet-rs:principleAssessed", "@type": "@id" },
    "hasNonConformity":            { "@id": "comet-rs:hasNonConformity", "@type": "@id" },
    "applicableDPL":               { "@id": "comet-rs:applicableDPL", "@type": "@id" },
    "claimDPLContext":             { "@id": "comet-rs:claimDPLContext", "@type": "@id" },
    "includesGHGScope":            { "@id": "comet-rs:includesGHGScope", "@type": "@id" },
    "productionRoute":             { "@id": "comet-rs:productionRoute", "@type": "@id" }
  }
}
