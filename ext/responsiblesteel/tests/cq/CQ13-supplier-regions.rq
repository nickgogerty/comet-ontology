# CQ13: List supplier tier regions per site
# Competency Question: Show the supplier tiers and regions covered by each site's sourcing engagement

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX comet-rs: <https://comet.carbon/ext/responsiblesteel#>

SELECT ?site ?siteLabel ?splValue ?splAssessmentYear ?supplierTiersCovered
WHERE {
  ?site rdf:type comet-rs:CertifiedSite ;
        rdfs:label ?siteLabel ;
        comet-rs:hasSourcingProgressLevel ?spl .

  ?spl comet-rs:splValue ?splValue ;
       comet-rs:assessmentYear ?splAssessmentYear ;
       comet-rs:supplierTiersCovered ?supplierTiersCovered .
}
ORDER BY DESC(?splValue) ?siteLabel
