# CQ01: What DPL does each certified site achieve?
# Competency Question: List all certified sites with their current Decarbonization Progress Level (DPL)

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX comet-rs: <https://comet.carbon/ext/responsiblesteel#>

SELECT ?site ?siteLabel ?certificateId ?dplValue
WHERE {
  ?site rdf:type comet-rs:CertifiedSite ;
        rdfs:label ?siteLabel ;
        comet-rs:certificateId ?certificateId ;
        comet-rs:hasDecarbProgressLevel ?dpl .

  ?dpl comet-rs:dplValue ?dplValue .
}
ORDER BY DESC(?dplValue) ?siteLabel
