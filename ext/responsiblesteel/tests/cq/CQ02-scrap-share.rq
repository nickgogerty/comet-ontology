# CQ02: What is the scrap share for each site?
# Competency Question: List all certified sites with their scrap share percentage

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX comet-rs: <https://comet.carbon/ext/responsiblesteel#>

SELECT ?site ?siteLabel ?scrapSharePercentage ?calculationMethod ?reportingYear
WHERE {
  ?site rdf:type comet-rs:CertifiedSite ;
        rdfs:label ?siteLabel ;
        comet-rs:hasScrapShareCalculation ?scrapCalc .

  ?scrapCalc comet-rs:sharePercentage ?scrapSharePercentage ;
             comet-rs:calculationMethod ?calculationMethod ;
             comet-rs:reportingYear ?reportingYear .
}
ORDER BY DESC(?scrapSharePercentage) ?siteLabel
