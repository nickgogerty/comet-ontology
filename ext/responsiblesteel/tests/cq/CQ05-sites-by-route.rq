# CQ05: Which sites use each production route?
# Competency Question: Group certified sites by their production route (BF-BOF, EAF, DRI-EAF, etc.)

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX comet-rs: <https://comet.carbon/ext/responsiblesteel#>

SELECT ?route (COUNT(?site) as ?siteCount) (GROUP_CONCAT(?siteLabel; separator=", ") as ?sites)
WHERE {
  ?site rdf:type comet-rs:CertifiedSite ;
        rdfs:label ?siteLabel ;
        comet-rs:hasProductionRoute ?route .
}
GROUP BY ?route
ORDER BY ?route
